{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VIGIL",
  "version": "0.0.2",
  "identifier": "dev.erayates.vigil",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VIGIL FOCUS \u2014 Roman Focus Companion",
        "width": 1600,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": true
      },
      {
        "label": "companion",
        "title": "VIGIL Companion",
        "url": "index.html?window=companion",
        "width": 240,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Roman-inspired pixel-art focus companion.",
    "longDescription": "VIGIL turns a single mission and a focus interval into a calm desktop ritual with a Roman-inspired pixel-art companion.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
