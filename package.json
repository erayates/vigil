{
  "name": "vigil-focus",
  "version": "0.2.0",
  "private": true,
  "description": "Roman-inspired pixel-art desktop focus companion built with Tauri, React and TypeScript.",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "assets:generate": "python scripts/generate_pixel_assets.py && npm run assets:manifest",
    "version:check": "node scripts/check-version.mjs",
    "test:ui": "vitest run src/widgets",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "preview:capture": "npm run build && node scripts/capture-ui-preview.mjs",
    "assets:manifest": "python scripts/build_asset_manifest.py && prettier --write docs/assets/asset-manifest.json",
    "docs:tree": "python scripts/build_project_tree.py"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.61.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.10.1",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "jsdom": "27.3.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
